{
  "compilerOptions": {
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "ES2020",
    "outDir": "./dist",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "jsx": "react-jsx"
  },
  "include": [
    "server.ts",
    "server/**/*",
    "services/**/*",
    "scripts/**/*",
    "types.ts",
    "constants.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "vite.config.ts"
  ]
}
